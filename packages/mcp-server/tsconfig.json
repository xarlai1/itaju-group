{
  "compilerOptions": {
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.json",
    "outDir": "./build",
    "noEmit": false,
    "strict": false,
    "target": "ES2024",
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "module": "nodenext",
    "moduleResolution": "nodenext"
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/__tests__"]
}
